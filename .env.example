# Base PostgreSQL (URL complète)
DATABASE_URL=postgresql://user:motdepasse@localhost:5432/hub

# Serveur
PORT=4000
NODE_ENV=development

# JWT — générer une chaîne longue aléatoire en production
JWT_SECRET=changez_moi_en_production_minimum_32_caracteres
JWT_EXPIRES_IN=30d

# URL publique du backend (emails, liens futurs)
APP_URL=http://localhost:4000

# Origines CORS autorisées pour le front React (séparateur virgule si plusieurs)
FRONTEND_URL=http://localhost:5173

# SMTP (optionnel au Module 0 : si absent, les emails sont journalisés en console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Wave (business.wave.com / dev-portal) — Mobile Money CI, devise XOF
WAVE_API_KEY=
# Secret webhook (distinct de la clé API) — Portail Wave > Webhooks
WAVE_WEBHOOK_SECRET=
# Optionnel : signature des requêtes API sortantes (si activée sur la clé API)
WAVE_SIGNING_SECRET=
# Optionnel : URL API (défaut https://api.wave.com)
# WAVE_API_BASE_URL=https://api.wave.com
